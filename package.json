{
  "name": "mcp-dev-mesh-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "dev:server": "pnpm --filter @mcp-dev-mesh/mesh-server dev",
    "dev:client": "pnpm --filter mcp-dev-mesh dev"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
