{
  "name": "devmesh-workspace",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck && pnpm typecheck:examples",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:contract && pnpm test:integration && pnpm test:security && pnpm test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "pnpm --filter devmesh... build && vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:e2e": "pnpm --filter @devmesh/mesh-server... build && vitest run --config vitest.e2e.config.ts",
    "dev:server": "pnpm --filter @devmesh/mesh-server dev",
    "dev:admin": "pnpm --filter @devmesh/web-admin dev",
    "dev:client": "pnpm --filter devmesh dev",
    "dev:website": "pnpm --filter @devmesh/website start",
    "build:website": "pnpm --filter @devmesh/website build",
    "version:check": "node scripts/check-release-version.mjs",
    "release:check": "pnpm version:sync && pnpm version:check && pnpm typecheck && pnpm test && pnpm build && node scripts/smoke-npm-package.mjs --skip-build",
    "npm:smoke": "node scripts/smoke-npm-package.mjs",
    "docker:config": "docker compose -f deploy/docker-compose.yml config",
    "docker:build": "docker compose -f deploy/docker-compose.yml build",
    "docker:up": "docker compose -f deploy/docker-compose.yml up --build",
    "docker:up:detached": "docker compose -f deploy/docker-compose.yml up --build -d",
    "docker:smoke": "node scripts/smoke-docker-stack.mjs",
    "docker:down": "docker compose -f deploy/docker-compose.yml down",
    "docker:down:volumes": "docker compose -f deploy/docker-compose.yml down -v",
    "version:sync": "node scripts/sync-release-version.mjs"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa__router": "^12.0.5",
    "@types/node": "22.19.20",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
